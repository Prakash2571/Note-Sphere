# ============================================================
#  Note-Sphere — Environment Variables
#  Copy this file to .env.local and fill in your values.
#  Never commit .env.local to source control.
# ============================================================


# ── App URL ──────────────────────────────────────────────────────────────────
# Full URL of your app (no trailing slash).
# Used by Auth.js to build callback URLs and by share link generation.
AUTH_URL=http://localhost:3000


# ── Auth.js v5 Secret ────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
# Must be at least 32 characters. Keep it secret.
AUTH_SECRET=your_random_secret_here_min_32_chars


# ── Google OAuth ─────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Authorised redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=your_google_client_id_here
AUTH_GOOGLE_SECRET=your_google_client_secret_here


# ── MongoDB ───────────────────────────────────────────────────────────────────
# Get from: MongoDB Atlas → Connect → Drivers → Node.js
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/note-sphere?retryWrites=true&w=majority


# ── AWS S3 ────────────────────────────────────────────────────────────────────
# Create an IAM user at https://console.aws.amazon.com/iam
# Attach the AmazonS3FullAccess policy (or a scoped custom policy).
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=your_s3_bucket_name


# ── Google Gemini AI ──────────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
