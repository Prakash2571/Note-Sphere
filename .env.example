# ============================================================
#  Note-Sphere — Environment Variables
#  Copy this file to .env.local and fill in your values
# ============================================================

# --- App ---
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_random_secret_here_min_32_chars

# --- MongoDB ---
# Get this from MongoDB Atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/note-sphere?retryWrites=true&w=majority

# --- Google OAuth ---
# Create at https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# --- AWS S3 ---
# Create IAM user at https://console.aws.amazon.com/iam
# Attach AmazonS3FullAccess policy to that user
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_REGION=us-east-1
AWS_S3_BUCKET_NAME=your_s3_bucket_name

# --- Gemini AI ---
# Get API key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
